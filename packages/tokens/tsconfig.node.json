{
    "compilerOptions": {
        "allowJs": true,
        "allowSyntheticDefaultImports": true,
        "composite": true,
        "emitDeclarationOnly": true,
        "lib": ["ESNext"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "outDir": "./dist/tsconfig-node",
        "resolveJsonModule": true,
        "target": "ESNext"
    },
    "include": ["package.json", "oxlint.config.ts"]
}
