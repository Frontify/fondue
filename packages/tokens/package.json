{
    "name": "@frontify/fondue-tokens",
    "type": "module",
    "version": "5.0.3",
    "description": "Single source of truth for Fondue Design Tokens",
    "author": "Frontify Developers <developers@frontify.com>",
    "homepage": "https://github.com/Frontify/fondue",
    "repository": {
        "type": "git",
        "url": "https://github.com/Frontify/fondue",
        "directory": "packages/tokens"
    },
    "bugs": {
        "url": "https://github.com/frontify/fondue/issues"
    },
    "keywords": [
        "fondue",
        "design",
        "tokens",
        "variables"
    ],
    "exports": {
        "./styles": "./dist/css/base.css",
        "./tailwind": "./dist/tailwind/tailwind.config.js",
        "./themes": {
            "types": "./dist/themes/themes.module.css.d.ts",
            "import": "./dist/themes/themes.module.css"
        },
        "./json": "./dist/json/all-tokens.json",
        "./json/colors": "./dist/json/colors.json",
        "./json/semantic": "./dist/json/semantic.json",
        "./json/utilities": "./dist/json/utilities.json",
        "./legacy/tokens": "./dist/legacy/deprecatedBaseTokens.css",
        "./legacy/tailwind": "./dist/legacy/deprecatedTailwindConfig.ts",
        "./legacy/tools/replaceLegacyTokens": "./tools/replaceLegacyTokens.ts",
        "./manifest.json": "./dist/manifest.json"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsx src/buildTokens.ts && cp -r legacyTokens/* ./dist/legacy && mkdir -p ./dist/legacy/tools && cp -r tools/* ./dist/legacy/tools",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "migrate": "tsx tools/migrate.js",
        "typecheck": "tsgo --noEmit",
        "build:storybook": "tailwindcss -o .storybook/styles.css && storybook build",
        "storybook": "storybook dev -p 6005"
    },
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "tailwindcss": "^3.4.17"
    },
    "dependencies": {
        "react": "^18.3.1"
    },
    "devDependencies": {
        "@frontify/fondue-components": "workspace:*",
        "@frontify/fondue-icons": "workspace:*",
        "@frontify/oxfmt-config": "^0.0.2",
        "@frontify/oxlint-config-basic": "^0.0.2",
        "@frontify/oxlint-config-react": "^0.0.2",
        "@storybook/addon-a11y": "^10.3.6",
        "@storybook/addon-docs": "^10.3.6",
        "@storybook/addon-links": "^10.3.6",
        "@storybook/react-vite": "^10.3.6",
        "@tony.ganchev/eslint-plugin-header": "^3.4.4",
        "@types/node": "^24.10.9",
        "@types/react": "^18.3.27",
        "@types/react-dom": "^18.3.7",
        "@typescript/native-preview": "7.0.0-dev.20260421.2",
        "@vitejs/plugin-react": "^5.1.2",
        "eslint-plugin-tailwindcss": "^3.18.2",
        "oxfmt": "^0.52.0",
        "oxlint": "^1.67.0",
        "oxlint-tsgolint": "^0.23.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "storybook": "^10.3.6",
        "style-dictionary": "^4.4.0",
        "tailwindcss": "^3.4.19",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
