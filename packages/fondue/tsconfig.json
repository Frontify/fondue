{
    "compilerOptions": {
        "allowJs": true,
        "esModuleInterop": true,
        "jsx": "react-jsx",
        "lib": ["dom", "dom.iterable", "esnext"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "noUnusedLocals": true,
        "paths": {
            "@components/*": ["./src/components/*"],
            "@foundation/*": ["./src/foundation/*"],
            "@hooks/*": ["./src/hooks/*"],
            "@layout/*": ["./src/layout/*"],
            "@typography/*": ["./src/typography/*"],
            "@utilities/*": ["./src/utilities/*"]
        },
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "esnext",
        "types": ["vite/client", "node"]
    },
    "exclude": [
        "node_modules",
        "dist",
        "src/foundation/Icon/Generated",
        "src/foundation/Icon/IconEnum.ts"
    ],
    "include": [
        ".storybook",
        "oxlint.config.ts",
        "oxfmt.config.ts",
        "postcss.config.cjs",
        "src",
        "scripts",
        "vite.config.ts",
        "tailwind.config.js",
        "components.vite.config.ts",
        "charts.vite.config.ts",
        "icons.vite.config.ts",
        "rte.vite.config.ts",
        "sdk.vite.config.ts",
        "legacyComponents.tailwind.config.ts",
        "tokens.vite.config.ts",
        "codemod.vite.config.ts",
        "internal-tools.vite.config.ts",
        "sdk-cli.vite.config.ts",
        "legacyTokens",
        "tools"
    ],
    "ts-node": {
        "files": true
    }
}
